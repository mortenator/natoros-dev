{
  "name": "natoros-product",
  "displayName": "NatorOS Product MCP",
  "description": "Authenticated MCP surface for operating on customer NatorOS workspace data through the public API.",
  "iconUrl": "https://www.natoros.com/favicon.ico",
  "version": "2026-05-21",
  "serverUrl": "https://www.natoros.com/api/mcp-product",
  "documentationUrl": "https://www.natoros.com/docs/api#mcp",
  "sourceUrl": "https://github.com/mortenator/natoros-dev",
  "instructions": "Use Authorization: Bearer ntr_live_... with a NatorOS API key. Production writes require Idempotency-Key.",
  "authorization": {
    "type": "api_key",
    "header": "Authorization",
    "scheme": "Bearer",
    "prefix": "ntr_live_",
    "scopes": ["agents:read", "workflows:read", "workflows:write", "runs:read", "records:read", "records:write", "webhooks:write"]
  },
  "tools": [
    { "name": "natoros_list_agents", "description": "List workspace agents.", "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false } },
    { "name": "natoros_list_workflows", "description": "List workspace workflows.", "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false } },
    { "name": "natoros_list_workflow_runs", "description": "List workspace workflow runs.", "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false } },
    { "name": "natoros_list_records", "description": "List workspace records by object type.", "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false } },
    { "name": "natoros_create_workflow_run", "description": "Create a production workflow run.", "annotations": { "readOnlyHint": false, "destructiveHint": false, "idempotentHint": false, "openWorldHint": false } },
    { "name": "natoros_create_task", "description": "Create a task.", "annotations": { "readOnlyHint": false, "destructiveHint": false, "idempotentHint": false, "openWorldHint": false } },
    { "name": "natoros_update_task", "description": "Update a task.", "annotations": { "readOnlyHint": false, "destructiveHint": false, "idempotentHint": true, "openWorldHint": false } }
  ]
}
