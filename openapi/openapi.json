            ]
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/WorkflowList"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "Workflows"
        ],
        "operationId": "createWorkflow",
        "summary": "Create a workflow asynchronously",
        "security": [
          {
            "oauth2": [
              "workflows:write"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedJob"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v1/workflow-runs": {
      "get": {
        "tags": [
          "Runs"
        ],
        "operationId": "listWorkflowRuns",
        "summary": "List workflow runs",
        "security": [
          {
            "oauth2": [
              "runs:read"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/RunList"
          }
        }
      }
    },
    "/v1/workflow-runs/{runId}": {
      "get": {
        "tags": [
          "Runs"
        ],
        "operationId": "getWorkflowRun",
        "summary": "Get a workflow run",
        "security": [
          {
            "oauth2": [
              "runs:read"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Run"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v1/records": {
      "get": {
        "tags": [
          "Records"
        ],
        "operationId": "listRecords",
        "summary": "List operational records",
        "security": [
          {
            "oauth2": [
              "records:read"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "name": "object",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "person",
                "company",
                "deal",
                "task",
                "project"
              ]
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/RecordList"
          }
        }
      },
      "post": {
        "tags": [
          "Records"
        ],
        "operationId": "createRecord",
        "summary": "Create a record",
        "security": [
          {
            "oauth2": [
              "records:write"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedRecordMutation"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "patch": {
        "tags": [
          "Records"
        ],
        "operationId": "updateRecord",
        "summary": "Update a record",
        "security": [
          {
            "oauth2": [
              "records:write"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedRecordMutation"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v1/tasks": {
      "get": {
        "tags": [
