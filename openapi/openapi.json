{
  "openapi": "3.1.0",
  "info": {
    "title": "NatorOS Public API",
    "version": "2026-05-21",
    "description": "Public API for discovering and integrating with NatorOS, the agentic OS and AI OS for enterprise operations. Production writes require scoped credentials. Sandbox endpoints are safe for autonomous agents."
  },
  "servers": [
    {
      "url": "https://www.natoros.com/api"
    }
  ],
  "security": [
    {
      "NatorOSApiKey": []
    }
  ],
  "tags": [
    {
      "name": "Agents"
    },
    {
      "name": "Workflows"
    },
    {
      "name": "Runs"
    },
    {
      "name": "Records"
    },
    {
      "name": "Projects"
    },
    {
      "name": "Webhooks"
    },
    {
      "name": "Sandbox"
    }
  ],
  "paths": {
    "/v1/agents": {
      "get": {
        "tags": [
          "Agents"
        ],
        "operationId": "listAgents",
        "summary": "List available NatorOS AI workers",
        "security": [
          {
            "oauth2": [
              "agents:read"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/AgentList"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "429": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "Agents"
        ],
        "operationId": "createAgent",
        "summary": "Create or update a governed AI worker asynchronously",
        "security": [
          {
            "oauth2": [
              "agents:write"
            ]
          },
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedJob"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "422": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v1/workflows": {
      "get": {
        "tags": [
